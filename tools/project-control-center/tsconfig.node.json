{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true,
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["src/core/**/*.ts", "src/server/**/*.ts", "src/cli/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/tests/**/*.ts"]
}
