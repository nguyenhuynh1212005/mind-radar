{
  "name": "@diemmanh/project-control-center",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "build": "vite build && npm run build:node",
    "build:node": "tsc -p tsconfig.node.json",
    "scan": "npm run build:node && node dist/src/cli/scan.js"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "typescript": "^5.5.4",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
